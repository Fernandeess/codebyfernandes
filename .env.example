# Environment Configuration for Blog Management System

# ========== BACKEND CONFIGURATION ==========

# Spring Profile (dev, docker, prod)
SPRING_PROFILES_ACTIVE=dev

# Server
SPRING_SERVER_PORT=8080
SPRING_SERVER_SERVLET_CONTEXT_PATH=/

# Database (H2 for development)
SPRING_DATASOURCE_URL=jdbc:h2:mem:testdb
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.h2.Driver
SPRING_DATASOURCE_USERNAME=sa
SPRING_DATASOURCE_PASSWORD=

# JPA/Hibernate
SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.H2Dialect
SPRING_JPA_HIBERNATE_DDL_AUTO=create-drop
SPRING_JPA_SHOW_SQL=false

# JWT Configuration
JWT_SECRET=mySecretKeyForBlogApiThatIsAtLeast32CharactersLongAndSecure
JWT_EXPIRATION=86400000

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,Accept
CORS_ALLOW_CREDENTIALS=true

# ========== FRONTEND CONFIGURATION ==========

# Angular Environment
NODE_ENV=development
ANGULAR_ENV=development

# API Base URL
API_BASE_URL=http://localhost:8080/api

# ========== PRODUCTION CONFIGURATION ==========
# Uncomment and adjust for production deployment

# SPRING_PROFILES_ACTIVE=prod
# SPRING_DATASOURCE_URL=jdbc:postgresql://db-host:5432/blog_db
# SPRING_DATASOURCE_USERNAME=postgres
# SPRING_DATASOURCE_PASSWORD=your_password_here
# SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.PostgreSQL10Dialect
# 
# JWT_SECRET=your_production_secret_key_here
# JWT_EXPIRATION=86400000
# 
# CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://api.yourdomain.com
# 
# JAVA_OPTS=-Xmx512m -Xms256m

# ========== DOCKER CONFIGURATION ==========

# Docker Compose
COMPOSE_PROJECT_NAME=blog-app
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1

# Docker Registry (for pushing to Docker Hub)
DOCKER_REGISTRY=docker.io
DOCKER_REGISTRY_USERNAME=your_dockerhub_username
DOCKER_REGISTRY_PASSWORD=your_dockerhub_password

# ========== LOGGING ==========

LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_CODEBYFERNANDES=DEBUG
